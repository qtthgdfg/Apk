class UserManager:
    def __init__(self):
        self._sessions = {}
        self._session_lock = threading.Lock()
    
    def authenticate(self, username: str, password: str) -> Optional[Tuple[str, UserRole]]:
        password_hash = hashlib.sha256(password.encode()).hexdigest()
        
        with db.transaction() as conn:
            user = conn.execute("""
                SELECT user_id, username, role FROM users 
                WHERE username = ? AND password_hash = ? AND is_active = 1
            """, (username, password_hash)).fetchone()
            
            if user:
                conn.execute(
                    "UPDATE users SET last_login = ? WHERE user_id = ?",
                    (int(time.time()), user['user_id'])
                )
                
                session_token = secrets.token_hex(32)
                with self._session_lock:
                    self._sessions[session_token] = {
                        'user_id': user['user_id'],
                        'username': user['username'],
                        'role': UserRole(user['role']),
                        'expires': time.time() + 3600
                    }
                
                return session_token, UserRole(user['role'])
        
        return None, None
    
    def verify_session(self, session_token: str) -> Optional[Dict]:
        with self._session_lock:
            if session_token in self._sessions:
                session = self._sessions[session_token]
                if session['expires'] > time.time():
                    return session
                else:
                    del self._sessions[session_token]
        return None
    
    def logout(self, session_token: str):
        with self._session_lock:
            if session_token in self._sessions:
                del self._sessions[session_token]
    
    def create_user(self, username: str, password: str, role: UserRole) -> bool:
        try:
            password_hash = hashlib.sha256(password.encode()).hexdigest()
            with db.transaction() as conn:
                conn.execute("""
                    INSERT INTO users (username, password_hash, role, created_at)
                    VALUES (?, ?, ?, ?)
                """, (username, password_hash, role.value, int(time.time())))
            return True
        except sqlite3.IntegrityError:
            return False
    
    def log_audit(self, user_id: int, action: str, target_type: str, target_id: str, details: str, ip_address: str):
        with db.transaction() as conn:
            conn.execute("""
                INSERT INTO audit_log (user_id, action, target_type, target_id, timestamp, ip_address, details)
                VALUES (?, ?, ?, ?, ?, ?, ?)
            """, (user_id, action, target_type, target_id, int(time.time()), ip_address, details))

